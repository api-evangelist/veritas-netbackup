{
  "@context": {
    "@version": 1.1,
    "nbu": "https://sort.veritas.com/schemas/netbackup/",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "dcterms": "http://purl.org/dc/terms/",

    "Job": {
      "@id": "nbu:Job",
      "@context": {
        "jobId": "nbu:jobId",
        "parentJobId": "nbu:parentJobId",
        "jobType": "nbu:jobType",
        "state": "nbu:jobState",
        "status": "nbu:statusCode",
        "policyName": "nbu:policyName",
        "policyType": "nbu:policyType",
        "scheduleName": "nbu:scheduleName",
        "scheduleType": "nbu:scheduleType",
        "clientName": "nbu:clientName",
        "mediaServer": "nbu:mediaServer",
        "storageUnit": "nbu:storageUnit",
        "startTime": {
          "@id": "nbu:startTime",
          "@type": "xsd:dateTime"
        },
        "endTime": {
          "@id": "nbu:endTime",
          "@type": "xsd:dateTime"
        },
        "elapsedTime": "nbu:elapsedTime",
        "kilobytesTransferred": "nbu:kilobytesTransferred",
        "filesTransferred": "nbu:filesTransferred",
        "percentComplete": "nbu:percentComplete",
        "currentOperation": "nbu:currentOperation",
        "attempt": "nbu:attempt",
        "restartable": "nbu:restartable",
        "suspendable": "nbu:suspendable",
        "resumable": "nbu:resumable",
        "cancellable": "nbu:cancellable",
        "backupId": "nbu:backupId"
      }
    },

    "Policy": {
      "@id": "nbu:Policy",
      "@context": {
        "policyName": "nbu:policyName",
        "policyType": "nbu:policyType",
        "active": "nbu:active",
        "effectiveDate": {
          "@id": "nbu:effectiveDate",
          "@type": "xsd:dateTime"
        },
        "priority": "nbu:priority",
        "keyword": "nbu:keyword",
        "dataClassification": "nbu:dataClassification",
        "clients": {
          "@id": "nbu:clients",
          "@container": "@set"
        },
        "schedules": {
          "@id": "nbu:schedules",
          "@container": "@set"
        },
        "backupSelections": {
          "@id": "nbu:backupSelections",
          "@container": "@set"
        },
        "backupCopies": {
          "@id": "nbu:backupCopies",
          "@container": "@set"
        }
      }
    },

    "Client": {
      "@id": "nbu:Client",
      "@context": {
        "hostName": "schema:name",
        "hostType": "nbu:hostType",
        "os": "nbu:operatingSystem",
        "platform": "nbu:platform",
        "version": "schema:softwareVersion",
        "fingerprintSha256": "nbu:fingerprintSha256",
        "trustLevel": "nbu:trustLevel",
        "communicationStatus": "nbu:communicationStatus",
        "lastConnectedTime": {
          "@id": "nbu:lastConnectedTime",
          "@type": "xsd:dateTime"
        }
      }
    },

    "BackupImage": {
      "@id": "nbu:BackupImage",
      "@context": {
        "backupId": "nbu:backupId",
        "policyName": "nbu:policyName",
        "policyType": "nbu:policyType",
        "clientName": "nbu:clientName",
        "scheduleName": "nbu:scheduleName",
        "scheduleType": "nbu:scheduleType",
        "backupTime": {
          "@id": "nbu:backupTime",
          "@type": "xsd:dateTime"
        },
        "expirationTime": {
          "@id": "nbu:expirationTime",
          "@type": "xsd:dateTime"
        },
        "kilobytes": "nbu:kilobytes",
        "numberOfFiles": "nbu:numberOfFiles",
        "primaryCopy": "nbu:primaryCopy",
        "copyCount": "nbu:copyCount",
        "mediaServer": "nbu:mediaServer",
        "storageUnit": "nbu:storageUnit",
        "mediaId": "nbu:mediaId",
        "compressed": "nbu:compressed",
        "encrypted": "nbu:encrypted",
        "multiplexed": "nbu:multiplexed",
        "retentionLevel": "nbu:retentionLevel"
      }
    },

    "Schedule": {
      "@id": "nbu:Schedule",
      "@context": {
        "scheduleName": "nbu:scheduleName",
        "scheduleType": "nbu:scheduleType",
        "frequency": "nbu:frequency",
        "retentionPeriod": "nbu:retentionPeriod",
        "storageUnit": "nbu:storageUnit",
        "mediaMultiplexing": "nbu:mediaMultiplexing",
        "syntheticBackup": "nbu:syntheticBackup"
      }
    },

    "PolicyClient": {
      "@id": "nbu:PolicyClient",
      "@context": {
        "clientName": "nbu:clientName",
        "hardware": "nbu:hardware",
        "operatingSystem": "nbu:operatingSystem",
        "priority": "nbu:clientPriority"
      }
    },

    "TryLog": {
      "@id": "nbu:TryLog",
      "@context": {
        "tryNumber": "nbu:tryNumber",
        "pid": "nbu:processId",
        "statusCode": "nbu:statusCode",
        "statusMessage": "nbu:statusMessage",
        "startTime": {
          "@id": "nbu:tryStartTime",
          "@type": "xsd:dateTime"
        },
        "endTime": {
          "@id": "nbu:tryEndTime",
          "@type": "xsd:dateTime"
        },
        "mediaServer": "nbu:mediaServer",
        "storageUnit": "nbu:storageUnit",
        "kilobytesTransferred": "nbu:kilobytesTransferred",
        "filesTransferred": "nbu:filesTransferred"
      }
    },

    "StorageUnit": {
      "@id": "nbu:StorageUnit",
      "@context": {
        "name": "schema:name",
        "storageType": "nbu:storageType",
        "mediaServer": "nbu:mediaServer",
        "diskPool": "nbu:diskPool",
        "maxConcurrentJobs": "nbu:maxConcurrentJobs",
        "maxFragmentSize": "nbu:maxFragmentSize"
      }
    }
  }
}
